APP_ENV=local
DATABASE_URL=sqlite:///./qharisma_video_factory.db
MEDIA_DIR=./media
MOCK_PROVIDERS_ENABLED=true

QVF_LLM_PROVIDER=openai
OPENAI_API_KEY=
QVF_OPENAI_MODEL=gpt-5.5

QVF_GENERATION_MODE=mock
QVF_ALLOW_REAL_SPEND=false
QVF_MAX_VIDEO_SECONDS_PER_RUN=5
QVF_MAX_SCENES_PER_REAL_RUN=1
QVF_MAX_PROVIDER_POLL_SECONDS=600

QVF_VIDEO_PROVIDER=runway
RUNWAYML_API_SECRET=
QVF_RUNWAY_MODEL=gen4.5
QVF_VIDEO_RATIO=720:1280
QVF_VIDEO_SCENE_DURATION=5

QVF_AUTH_REQUIRED=true
QVF_PUBLIC_PILOT_MODE=true

SUPABASE_URL=
SUPABASE_PROJECT_REF=
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=
SUPABASE_ISSUER=
SUPABASE_AUDIENCE=authenticated

QVF_SESSION_COOKIE_NAME=qvf_session
QVF_SESSION_COOKIE_SECURE=false
QVF_SESSION_COOKIE_SAMESITE=lax
