QVF_DATABASE_URL=sqlite:///./qharisma.db
QVF_MEDIA_ROOT=media
QVF_RUNTIME_PROFILE=development
QVF_AUTO_INIT_DB=true
QVF_PUBLIC_APP_URL=
QVF_STORAGE_BACKEND=local
QVF_MEDIA_SIGNING_SECRET=
QVF_MOCK_PROVIDER_ENABLED=true

QVF_LLM_PROVIDER=openai
OPENAI_API_KEY=
QVF_OPENAI_MODEL=gpt-5.5

QVF_GENERATION_MODE=mock
QVF_ALLOW_REAL_SPEND=false
QVF_MASS_GENERATION_CREDIT_LIMIT=30000
QVF_MAX_VIDEO_SECONDS_PER_RUN=5
QVF_MAX_SCENES_PER_REAL_RUN=1
QVF_MAX_PROVIDER_POLL_SECONDS=600

QVF_VIDEO_PROVIDER=runway
RUNWAYML_API_SECRET=
QVF_RUNWAY_MODEL=gen4.5
QVF_VIDEO_RATIO=720:1280
QVF_VIDEO_SCENE_DURATION=5

# Optional explicit media-tool paths for Windows/services where PATH is minimal.
# FFprobe can be set separately or discovered next to the configured FFmpeg.
QVF_FFMPEG_PATH=
QVF_FFPROBE_PATH=
QVF_TESSERACT_PATH=
# Optional user-writable directory containing rus/eng traineddata files.
QVF_TESSDATA_PREFIX=

# Official social-metric OAuth tokens are resolved only from secret environment
# references stored in DestinationConnection. Never commit real values here.
YOUTUBE_ANALYTICS_ACCESS_TOKEN=
TIKTOK_OFFICIAL_ACCESS_TOKEN=
INSTAGRAM_OFFICIAL_ACCESS_TOKEN=
WB_SELLER_ANALYTICS_TOKEN=

QVF_AUTH_REQUIRED=true
QVF_PUBLIC_PILOT_MODE=true
QVF_PUBLIC_PILOT_INVITE_ONLY=true
QVF_LOCAL_AUTH_EMAIL=
QVF_LOCAL_AUTH_PASSWORD_HASH=
QVF_LOCAL_SESSION_SECRET=
QVF_LOCAL_SESSION_TTL_SECONDS=28800

SUPABASE_URL=
SUPABASE_PROJECT_REF=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
QVF_SUPABASE_STORAGE_BUCKET=contentengine-private
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=
SUPABASE_ISSUER=
SUPABASE_AUDIENCE=authenticated
QVF_SUPABASE_AUTH_TIMEOUT_SECONDS=8
QVF_SUPABASE_READINESS_TIMEOUT_SECONDS=5
QVF_SUPABASE_JWKS_CACHE_SECONDS=300
QVF_SUPABASE_JWT_CLOCK_SKEW_SECONDS=30

# Optional S3-compatible alternative to Supabase Storage.
QVF_S3_ENDPOINT_URL=
QVF_S3_BUCKET=
QVF_S3_REGION=us-east-1
QVF_S3_ACCESS_KEY_ID=
QVF_S3_SECRET_ACCESS_KEY=
QVF_S3_SESSION_TOKEN=

QVF_SESSION_COOKIE_NAME=qvf_session
QVF_SESSION_REFRESH_COOKIE_NAME=qvf_refresh
QVF_SESSION_REFRESH_COOKIE_MAX_AGE_SECONDS=2592000
QVF_SESSION_COOKIE_SECURE=false
QVF_SESSION_COOKIE_SAMESITE=lax
